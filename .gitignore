# =============================================================================
# HOSTEL MANAGEMENT SYSTEM — .gitignore
# Monorepo: Node.js Backend + React/TypeScript Frontend
# =============================================================================

# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
**/.env
**/.env.*
!**/.env.example

# ─── Build Outputs ───────────────────────────────────────────────────────────
dist/
build/
out/
**/dist/
**/build/

# ─── Vite / Frontend ─────────────────────────────────────────────────────────
packages/frontend/dist/
packages/frontend/.vite/
packages/frontend/stats.html

# ─── Backend ─────────────────────────────────────────────────────────────────
packages/backend/dist/
packages/backend/uploads/
packages/backend/logs/

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Runtime & Cache ─────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
*.tsbuildinfo

# ─── Testing ─────────────────────────────────────────────────────────────────
coverage/
**/coverage/
.nyc_output/

# ─── OS Generated ────────────────────────────────────────────────────────────
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~

# ─── Editor & IDE ────────────────────────────────────────────────────────────
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains
.idea/
*.iml
*.iws

# Vim / Emacs
*.swp
*.swo
*~
\#*\#

# ─── Database ────────────────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
*.db-journal

# ─── Package Manager Locks (keep one, ignore others) ─────────────────────────
# Uncomment the ones you do NOT use:
# yarn.lock
# pnpm-lock.yaml

# ─── Misc ────────────────────────────────────────────────────────────────────
*.pem
*.key
*.cert
*.crt
tmp/
temp/
.temp/
